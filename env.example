# PolyToPixel AMP environment template
# Copy to the AMP instance datastore as polytopixel.env after filling placeholders.
# Never commit real GitHub release tokens, tunnel tokens, or Access audience values.

POLYTOPIXEL_GITHUB_TOKEN=<configure-through-amp-secrets-read-releases-only>
POLYTOPIXEL_RELEASE_TAG=git-505af99ea71abd57949c481e6f213ed879b20e13
POLYTOPIXEL_RELEASE_ZIP_SHA256=5733db252b096d5f10d609064362c8c8be7d5b32fc785d982554aa48d2d79de6
APPLICATION_PORT=21617
SPRITESMITH_HOST=127.0.0.1
SPRITESMITH_PORT=21617
SPRITESMITH_DATA_ROOT=/workspace/spritesmith-data
SPRITESMITH_PROJECTS_DIR=/workspace/spritesmith-data/projects
SPRITESMITH_CACHE_ROOT=/workspace/spritesmith-cache
SPRITESMITH_LOG_ROOT=/workspace/spritesmith-data/logs
SPRITESMITH_TELEMETRY_DIR=/workspace/spritesmith-data/telemetry
SPRITESMITH_TEMP_ROOT=/workspace/spritesmith-data/tmp
SPRITESMITH_BACKUP_DEST_ROOT=/workspace/polytopixel-backups
SPRITESMITH_AUTH_MODE=cloudflare_access
CLOUDFLARE_ACCESS_TEAM_DOMAIN=<your-cloudflare-access-team-domain>
CLOUDFLARE_ACCESS_AUDIENCE=<your-cloudflare-access-audience>
BUNDLED_CLOUDFLARED_ENABLED=1
SPRITESMITH_CLOUDFLARE_TUNNEL_ENABLED=1
CLOUDFLARE_TUNNEL_TOKEN=<configure-through-amp-secrets>
SPRITESMITH_GPU_REQUIRED=false
SPRITESMITH_HEAVY_JOB_CONCURRENCY=1
SPRITESMITH_SERVE_FRONTEND=1
HEALTH_CHECK_PATH=/health/ready
